    elif command -v scoop  &>/dev/null; then
      printf "  Install ${B}%s${R} now via Scoop? [Y/n] → " "$_tool"; read -r _ans
      [[ "${_ans:-y}" =~ ^[Yy]$ ]] || { printf "  ${D}Skipping %s.${R}\n\n" "$_tool"; return; }
      scoop install "$_tool"
    else
      printf "  ${D}No package manager found. Install %s manually from https://nmap.org/download.html${R}\n\n" "$_tool"
